# Environment Variables - Copy to .env and fill in values

# Server Configuration
PORT=5000
NODE_ENV=development

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="your_firebase_private_key"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here

# Production URL (set when deploying with Cloudflare Tunnel)
# Example: https://edumentor.io.vn
PRODUCTION_URL=https://edumentor.io.vn

# Forgot Password Support
FORGOT_PASSWORD_SUPPORT_EMAIL=edumentor.hk@gmail.com

# Frontend app URL (used in reset password email link)
FRONTEND_APP_URL=http://localhost:3000

# SMTP Mailer (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=edumentor.hk@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=edumentor.hk@gmail.com

# Celery Worker Integration
CELERY_API_URL=http://localhost:8001
CELERY_API_TIMEOUT_MS=15000
INTERNAL_API_TOKEN=your_internal_token

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=edumentor:
